; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Arc-tillery"
config/version="0.2.0"
run/main_scene="uid://bi5b7j3y3f4wy"
config/features=PackedStringArray("4.5", "GL Compatibility")
config/icon="uid://1e14cqanvr2b"

[audio]

buses/default_bus_layout="uid://cntxqokmtanmb"

[autoload]

Events="*res://events.gd"
Game="*res://game.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_super-wakatime/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "gray",
"res://ui/": "green"
}

[gui]

theme/default_font_multichannel_signed_distance_field=true
theme/custom="uid://i3vbv3fax5ab"

